#!/usr/bin/env bash
set -e
set -u
set -o pipefail

if [ -t 0 ] && [ $# -eq 0 ]; then
  echo "Usage: expand <text>" >&2
  echo "       echo <text> | expand" >&2
  exit 1
fi

if [ $# -gt 0 ]; then
  echo "$*" | mods "Expand the following into a longer, more detailed and descriptive sentence while preserving the original meaning. Output only the expanded text with no explanation:"
else
  mods "Expand the following into a longer, more detailed and descriptive sentence while preserving the original meaning. Use simple business language. Output only the expanded text with no explanation:"
fi
