#!/usr/bin/env bash
set -e
set -u
set -o pipefail

if [[ $# -lt 2 ]]; then
  echo "Usage: videoclip <file> <start>-<end>"
  echo "Example: videoclip video.mp4 0:30-0:45"
  exit 1
fi

input="$1"
window="$2"

start="${window%-*}"
end="${window#*-}"

# Calculate duration from start and end times
duration=$(awk 'function to_seconds(t,  a,n) {
  n = split(t, a, ":")
  if (n == 3) return a[1]*3600 + a[2]*60 + a[3]
  if (n == 2) return a[1]*60 + a[2]
  return a[1]
}
BEGIN { print to_seconds(ARGV[1]) - to_seconds(ARGV[2]) }' "$end" "$start")

ext="${input##*.}"
base="${input%.*}"
output="${base}-clip.${ext}"

ffmpeg -i "$input" -ss "$start" -t "$duration" -c copy "$output"
