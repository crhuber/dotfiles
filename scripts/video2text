#!/usr/bin/env bash
set -e
set -o pipefail

# Usage: ./script.sh <input_file> [output_file]
# use https://github.com/ggml-org/whisper.cpp/blob/master/models/download-ggml-model.sh to download the model and place it in the same directory as this script
# uv tool install openai-whisper
# Check that at least one argument is provided
if [ $# -lt 1 ]; then
    echo "Usage: $0 <input_file> [output_file]"
    echo "Example: $0 video.mp4 output.srt"
    exit 1
fi

INPUT_FILE="$1"

# Check that the input file exists
if [ ! -f "$INPUT_FILE" ]; then
    echo "Error: Input file '$INPUT_FILE' not found."
    exit 1
fi

# If no output file is provided, derive it from the input filename
if [ -n "$2" ]; then
    OUTPUT_FILE="$2"
else
    BASENAME=$(basename "$INPUT_FILE")
    FILENAME="${BASENAME%.*}"
    OUTPUT_FILE="${FILENAME}.srt"
fi

whisper "$INPUT_FILE" --model base.en --language en --output_format srt

echo "Done! Output saved to: $OUTPUT_FILE"
